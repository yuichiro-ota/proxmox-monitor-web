# Proxmox host (IP or FQDN, without https://)

# Proxmox host (IP or FQDN, without https://)
PROXMOX_HOST=192.168.100.40

# Proxmox user (username@realm)
PROXMOX_USER=monitor@pve

# Proxmox API token name
PROXMOX_TOKEN_NAME=monitoring

# Proxmox API token value
PROXMOX_TOKEN_VALUE=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Proxmox verify SSL (true or false)
PROXMOX_VERIFY_SSL=false

# Output directory for logs and reports
OUTPUT_DIR=/output