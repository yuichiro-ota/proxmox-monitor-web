# Proxmox ホスト (IPアドレスまたはFQDN、https:// は不要)
PROXMOX_HOST=192.168.100.40

# Proxmox ユーザー (username@realm 形式)
PROXMOX_USER=monitor@pve

# Proxmox API トークン名
PROXMOX_TOKEN_NAME=monitoring

# Proxmox API トークン値
PROXMOX_TOKEN_VALUE=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# SSL証明書の検証 (true または false)
PROXMOX_VERIFY_SSL=false

# ログ・レポートの出力ディレクトリ
OUTPUT_DIR=/output

# Google Chat Webhook URL (通知機能を使う場合に設定)
# GOOGLE_CHAT_WEBHOOK_URL=https://chat.googleapis.com/v1/spaces/XXXXX/messages?key=...&token=...
